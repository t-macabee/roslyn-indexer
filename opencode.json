{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "model": "cohere/north-mini-code-1-0",
  "small_model": "cohere/north-mini-code-1-0",
  "share": "disabled",
  "autoupdate": "notify",
  "snapshot": true,
  "provider": {
    "cohere": {
      "options": {
        "timeout": 900000,
        "chunkTimeout": 60000
      },
      "models": {
        "north-mini-code-1-0": {
          "name": "North Mini Code 1.0",
          "interleaved": {
            "field": "reasoning"
          },
          "limit": {
            "context": 256000,
            "output": 64000
          }
        }
      }
    }
  },
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "allow",
      "git push*": "ask",
      "git reset*": "ask",
      "rm *": "ask",
      "Remove-Item*": "ask"
    },
    "webfetch": "deny",
    "websearch": "deny"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".vs/**",
      ".idea/**",
      "bin/**",
      "obj/**",
      "packages/**",
      "**/*.user",
      "**/*.suo"
    ]
  }
}
