{
  "env": {
    "BASE_URL": "https://api.deepseek.com"    
  },
  "model": "deepseek-v4-flash",
  "thinkingEnabled": true,
  "reasoningEffort": "high",
  "debugLogEnabled": false,
  "telemetryEnabled": false,
  "permissions": {
    "allow": [
      "read-in-cwd",
      "query-git-log",
      "mcp",
      "write-in-cwd",
      "network",
      "delete-in-cwd"
    ],
    "deny": [
      "read-out-cwd",
      "write-out-cwd",
      "delete-out-cwd",
      "mutate-git-log"
    ],
    "ask": [],
    "defaultMode": "askAll"
  },
  "mcpServers": {}
}
